# Servidor
PORT=3000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/adelcio-pinturas

# JWT
JWT_SECRET=seu_jwt_secret_super_seguro_aqui
JWT_EXPIRES_IN=7d

# Cloudinary (upload de imagens)
CLOUDINARY_CLOUD_NAME=seu_cloud_name
